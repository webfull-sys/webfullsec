// ============================================
// WebfullSec — Schema do Banco de Dados
// Autoria: Webfull (https://webfull.com.br)
// Versão: 2.2.0
// ============================================
// Reestruturado com 5 tabelas aprimoradas:
// Client, Project, Task, InboxItem, Memory
// + tabelas auxiliares para IA, logs e monitoramento.
// ============================================

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider   = "sqlite"
  url        = "file:./dev.db"
}

// ============================================
// Modelo: User (Admin único do sistema)
// ============================================
model User {
  id            String   @id @default(cuid())
  name          String   @default("Admin")
  email         String   @unique
  password      String
  timezone      String   @default("America/Sao_Paulo")
  workStartHour Int      @default(9)
  workEndHour   Int      @default(18)
  pomodoroWork  Int      @default(25)  // minutos de trabalho
  pomodoroBreak Int      @default(5)   // minutos de pausa
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relacionamentos
  dailyLogs        DailyLog[]
  pomodoroSessions PomodoroSession[]
}

// ============================================
// Modelo: Client (Clientes da agência)
// Tabela 1 — Aprimorada com nível de importância
// 1-5 e campos de contato expandidos.
// ============================================
model Client {
  id              String   @id @default(cuid())
  name            String
  email           String?
  phone           String?
  company         String?
  website         String?            // URL do site do cliente
  cpfCnpj         String?            // CPF ou CNPJ do cliente
  address         String?            // Endereço completo
  timezone        String   @default("America/Sao_Paulo")
  importanceLevel Int      @default(3) // 1=Muito Baixa, 2=Baixa, 3=Média, 4=Alta, 5=VIP
  tags            String?            // JSON array de tags (ex: ["wordpress","mensal"])
  notes           String?
  avatar          String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relacionamentos
  projects Project[]

  @@index([isActive])
  @@index([importanceLevel])
}

// ============================================
// Modelo: Project (Projetos vinculados a clientes)
// Tabela 2 — Aprimorada com contexto geral (memória IA),
// novos status (backlog, waiting_client) e data de início.
// ============================================
model Project {
  id             String    @id @default(cuid())
  title          String
  description    String?
  category       String    @default("site")           // site, automation, beat
  status         String    @default("backlog")         // backlog, in_progress, waiting_client, completed, archived
  priority       Int       @default(2)                 // 1=Baixa, 2=Média, 3=Alta, 4=Urgente
  generalContext String?                               // Escopo do projeto + memória da IA (onde parou, decisões, etc)
  clientId       String?
  startDate      DateTime?                             // Data planejada de início
  startedAt      DateTime?                             // Data real que iniciou
  dueDate        DateTime?                             // Prazo final de entrega
  completedAt    DateTime?                             // Data que foi concluído
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relacionamentos
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  tasks       Task[]
  memories    Memory[]
  projectLink ProjectLink?

  @@index([status])
  @@index([clientId])
  @@index([category])
}

// ============================================
// Modelo: Task (Tarefas — coração do sistema)
// Tabela 3 — Aprimorada com separação clara
// entre doDate (quando executar) e dueDate (prazo).
// ============================================
model Task {
  id            String    @id @default(cuid())
  title         String
  description   String?
  status        String    @default("inbox")   // inbox, todo, in_progress, done, cancelled
  priority      Int       @default(2)          // 1=Baixa, 2=Média, 3=Alta, 4=Urgente
  estimatedTime Int?                           // Tempo estimado em minutos (essencial para IA calcular o dia)
  actualTime    Int?                           // Tempo real gasto em minutos
  doDate        DateTime?                      // Data/hora que a IA agendou para EXECUTAR a tarefa
  dueDate       DateTime?                      // Data/hora LIMITE que o cliente precisa da entrega
  completedAt   DateTime?                      // Quando foi concluída
  tags          String?                        // JSON array de tags (ex: ["frontend","urgente"])
  recurrence    String?                        // Recorrência: daily, weekly, monthly, null
  projectId     String?
  parentId      String?                        // Para subtarefas
  position      Int       @default(0)          // Ordem de exibição
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relacionamentos
  project          Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  parent           Task?             @relation("SubTasks", fields: [parentId], references: [id], onDelete: SetNull)
  subtasks         Task[]            @relation("SubTasks")
  timeBlocks       TimeBlock[]
  pomodoroSessions PomodoroSession[]
  memories         Memory[]          // Logs de memória vinculados a esta tarefa

  @@index([status])
  @@index([doDate])
  @@index([dueDate])
  @@index([projectId])
  @@index([priority])
}

// ============================================
// Modelo: InboxItem (Caixa de entrada universal)
// Tabela 4 — Funil de captura rápida aprimorado
// com flag de processamento IA e conversão
// automática para tarefa/projeto.
// ============================================
model InboxItem {
  id                  String   @id @default(cuid())
  title               String
  content             String?                    // Conteúdo bruto da mensagem/ideia
  source              String   @default("manual") // manual, email, whatsapp, telegram, webhook, thought, voice, ai
  priority            Int      @default(2)
  isRead              Boolean  @default(false)
  isArchived          Boolean  @default(false)
  processedByAi       Boolean  @default(false)    // Flag: IA já processou este item?
  aiSummary           String?                     // Resumo gerado pela IA ao processar
  convertedToTaskId   String?                     // ID da tarefa criada a partir deste item
  convertedToProjectId String?                    // ID do projeto criado a partir deste item
  metadata            String?                     // JSON com dados extras da fonte
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([isRead, isArchived])
  @@index([processedByAi])
  @@index([source])
}

// ============================================
// Modelo: Memory (Logs de memória / "Onde eu parei?")
// Tabela 5 — Rastreador de contexto e progresso
// vinculado a projetos e/ou tarefas.
// ============================================
model Memory {
  id         String   @id @default(cuid())
  content    String                          // Resumo da ação (ex: "Finalizou bateria, falta mixar baixo")
  type       String   @default("progress")  // progress, decision, blocker, milestone, note, ai_summary
  projectId  String
  taskId     String?                         // Opcional: vincular a uma tarefa específica
  createdAt  DateTime @default(now())

  // Relacionamentos
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([taskId])
  @@index([type])
}

// ============================================
// Modelo: TimeBlock (Slots de tempo no calendário)
// ============================================
model TimeBlock {
  id        String   @id @default(cuid())
  title     String
  startTime DateTime
  endTime   DateTime
  color     String   @default("#00e5ff")
  taskId    String?
  isLocked  Boolean  @default(false) // Blocos fixos não podem ser reagendados
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

// ============================================
// Modelo: PomodoroSession (Sessões do timer)
// ============================================
model PomodoroSession {
  id          String   @id @default(cuid())
  startTime   DateTime
  endTime     DateTime?
  duration    Int      // Duração em minutos
  type        String   @default("work") // work, break
  isCompleted Boolean  @default(false)
  taskId      String?
  userId      String
  createdAt   DateTime @default(now())

  // Relacionamentos
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// Modelo: DailyLog (Rituais diários)
// ============================================
model DailyLog {
  id             String   @id @default(cuid())
  date           DateTime
  type           String   // start, shutdown
  plannedTasks   Int      @default(0)
  completedTasks Int      @default(0)
  totalHours     Float    @default(0)
  wins           String?  // Vitórias do dia (texto)
  notes          String?  // Notas adicionais
  mood           Int?     // 1-5 escala de humor
  userId         String
  createdAt      DateTime @default(now())

  // Relacionamentos
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// Modelo: AiConversation (Histórico de conversas IA)
// ============================================
model AiConversation {
  id        String   @id @default(cuid())
  title     String   @default("Nova Conversa")
  summary   String?  // Resumo gerado por IA da conversa
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos
  messages AiMessage[]
}

// ============================================
// Modelo: AiMessage (Mensagens do chat com IA)
// ============================================
model AiMessage {
  id             String   @id @default(cuid())
  role           String   // "user", "assistant", "system"
  content        String   // Conteúdo da mensagem
  toolCalls      String?  // JSON com chamadas de ferramentas executadas
  conversationId String
  createdAt      DateTime @default(now())

  // Relacionamentos
  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// ============================================
// Modelo: AiAction (Ações executadas pelo agente)
// ============================================
model AiAction {
  id          String   @id @default(cuid())
  type        String   // "create_task", "update_project", "send_notification", etc.
  description String   // Descrição legível da ação
  payload     String?  // JSON com parâmetros da ação
  result      String?  // JSON com resultado da execução
  status      String   @default("pending") // pending, success, failed
  triggeredBy String   @default("ai") // ai, user, automation
  createdAt   DateTime @default(now())
}

// ============================================
// Modelo: Notification (Central de notificações)
// ============================================
model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String?
  type      String   @default("info") // info, warning, success, error, reminder
  isRead    Boolean  @default(false)
  link      String?  // Link para a entidade relacionada
  createdAt DateTime @default(now())
}

// ============================================
// Modelo: Reminder (Lembretes inteligentes)
// ============================================
model Reminder {
  id          String    @id @default(cuid())
  title       String
  description String?
  remindAt    DateTime  // Data/hora do lembrete
  isCompleted Boolean   @default(false)
  isSent      Boolean   @default(false)
  recurrence  String?   // "daily", "weekly", "monthly", null
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============================================
// Modelo: ProjectLink (Vínculo com diretórios)
// ============================================
model ProjectLink {
  id         String    @id @default(cuid())
  projectId  String    @unique
  localPath  String    // Caminho no desktop (ex: C:\Users\...\projeto)
  vpsPath    String?   // Caminho no servidor VPS (ex: /var/www/projeto)
  gitRepo    String?   // URL do repositório Git
  techStack  String?   // JSON com tecnologias detectadas
  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relacionamentos
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ============================================
// Modelo: ServerMonitor (Monitoramento VPS)
// ============================================
model ServerMonitor {
  id          String    @id @default(cuid())
  name        String    // Nome amigável do servidor
  host        String    // IP ou domínio
  type        String    @default("vps") // vps, shared, dedicated
  sshPort     Int       @default(22)
  status      String    @default("unknown") // online, offline, degraded, unknown
  lastCheckAt DateTime?
  services    String?   // JSON com serviços monitorados
  notes       String?   // Notas sobre o servidor
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============================================
// Modelo: BurnoutLog (Guardião do Burnout)
// Score diário de risco de burnout com
// recomendações personalizadas da IA.
// ============================================
model BurnoutLog {
  id               String   @id @default(cuid())
  date             DateTime @unique          // Um registro por dia
  score            Int                       // 0-100 (0=zen, 100=burnout)
  level            String                    // low, moderate, high, critical
  workMinutes      Int      @default(0)      // Total trabalhado no dia
  tasksCompleted   Int      @default(0)
  tasksOverdue     Int      @default(0)
  breaksTaken      Int      @default(0)
  factors          String?                   // JSON com detalhes dos fatores de risco
  aiRecommendation String?                   // Recomendação gerada pela IA
  createdAt        DateTime @default(now())

  @@index([date])
  @@index([score])
}

// ============================================
// Modelo: Agent (Super Agentes IA)
// Especialistas virtuais (ex: Triagem, Projetos)
// ============================================
model Agent {
  id              String   @id @default(cuid())
  name            String
  description     String?
  systemPrompt    String   
  llmModel        String   @default("gemini-2.0-flash")
  webhookUrl      String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  interactions    AgentInteraction[]
}

// ============================================
// Modelo: AgentInteraction (Memória Infinita)
// Logs detalhados de cada ação do agente
// ============================================
model AgentInteraction {
  id              String   @id @default(cuid())
  agentId         String
  entityType      String   // project, task, client, inbox
  entityId        String?
  inputTrigger    String?   // JSON ou Texto (o que acordou o bot)
  outputResponse  String?   // Resposta ou ação
  createdAt       DateTime @default(now())

  agent           Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  
  @@index([agentId])
  @@index([entityType, entityId])
}

// ============================================
// Modelo: KnowledgeBase (Base de Conhecimento RAG)
// Documentos, SOPs e anotações vetorizadas
// ============================================
model KnowledgeBase {
  id              String   @id @default(cuid())
  title           String
  content         String   
  embeddingStr    String?   // Simulação local de vetor
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
